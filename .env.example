# PocketBase — URL pública de tu instancia
NEXT_PUBLIC_PB_URL=https://pocketbase.tudominio.com

# Nombre de las colecciones en PocketBase
NEXT_PUBLIC_PB_USERS=andreamoro_user
NEXT_PUBLIC_PB_DATA=andreamoro_data

# Token de admin (solo server-side, NO exponer al cliente)
# Usado para operaciones privilegiadas desde Server Components / API routes
PB_ADMIN_TOKEN=
